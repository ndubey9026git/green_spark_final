# Copy this file to .env and fill in values. DO NOT commit real secrets.
PORT=5000
MONGO_URI=your_production_mongodb_connection_string_here
JWT_SECRET=change_this_to_a_strong_random_string
# Comma-separated list of allowed origins for CORS (frontend URLs)
ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:5173
# Optional: API keys used by the backend
GEMINI_API_KEY=
